---
import type { SiteCopy } from '../../i18n/siteCopy';

interface Props {
	about: SiteCopy['about'];
}

const { about } = Astro.props;
---

<section class="section-shell about-flow" id="about">
	<div class="section-heading about-block">
		<p class="section-eyebrow">{about.eyebrow}</p>
		<h2>{about.title}</h2>
	</div>
	<div class="about-grid">
		{
			about.cards.map((card) => (
				<article class="panel about-block">
					<h3>{card.title}</h3>
					<p>{card.text}</p>
				</article>
			))
		}
	</div>
</section>
