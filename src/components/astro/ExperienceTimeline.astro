---
import type { SiteCopy } from '../../i18n/siteCopy';

interface Props {
	experience: SiteCopy['experience'];
	showHeading?: boolean;
}

const { experience, showHeading = true } = Astro.props;
---

<section class="section-shell" id="experience">
	{
		showHeading && (
			<div class="section-heading">
				<p class="section-eyebrow">{experience.eyebrow}</p>
				<h2>{experience.title}</h2>
			</div>
		)
	}
	<div class="timeline">
		{
			experience.jobs.map((job) => (
				<article class="panel timeline-item">
					<header>
						<h3>{job.role}</h3>
						<p>{job.company}</p>
						<small>
							{job.location} | {job.period}
						</small>
					</header>
					<ul>
						{job.points.map((point) => <li>{point}</li>)}
					</ul>
				</article>
			))
		}
	</div>
</section>
