---
import type { SiteCopy } from '../../i18n/siteCopy';

interface Props {
	hero: SiteCopy['hero'];
}

const { hero } = Astro.props;
---

<div class="hero-copy">
	<p class="eyebrow">{hero.eyebrow}</p>
	<h1>{hero.name}</h1>
	<p class="hero-summary">{hero.summary}</p>
	<div class="hero-actions">
		<a class="button button--primary" href="mailto:coldboycrio314@gmail.com">{hero.actions.email}</a>
		<a class="button button--ghost" href="https://www.dnd-codex.guide/" target="_blank" rel="noreferrer">
			{hero.actions.project}
		</a>
	</div>
	<ul class="fact-grid">
		{
			hero.facts.map((fact) => (
				<li class="fact-grid__item">
					<p>{fact.label}</p>
					<strong>{fact.value}</strong>
				</li>
			))
		}
	</ul>
</div>
