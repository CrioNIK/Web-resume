---
import type { SiteCopy } from '../../i18n/siteCopy';

interface Props {
	skills: SiteCopy['skills'];
}

const { skills } = Astro.props;
---

<section class="section-shell" id="skills">
	<div class="section-heading">
		<p class="section-eyebrow">{skills.eyebrow}</p>
		<h2>{skills.title}</h2>
	</div>
	<div class="skill-matrix">
		{
			skills.groups.map((group) => (
				<article class="panel">
					<h3>{group.title}</h3>
					<ul class="chip-list">
						{group.items.map((item) => <li>{item}</li>)}
					</ul>
				</article>
			))
		}
	</div>
</section>
