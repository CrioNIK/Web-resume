---
const groups = [
	{
		title: 'Основні технології',
		items: ['JavaScript (ES6+)', 'TypeScript', 'HTML5', 'CSS3']
	},
	{
		title: 'Фреймворки та UI',
		items: ['React 19', 'Next.js', 'Vite', 'Tailwind CSS', 'Framer Motion', 'React Router']
	},
	{
		title: 'Стан, форми, валідація',
		items: ['TanStack Query', 'React Hook Form', 'Zod']
	},
	{
		title: 'Інфраструктура',
		items: ['Node.js', 'Vercel', 'Docker', 'Git / GitHub', 'PWA', 'SSR / SSG']
	}
];
---

<section class="section-shell" id="skills">
	<div class="section-heading">
		<p class="section-eyebrow">Tech Stack</p>
		<h2>Стек, який дає швидкий UI і стабільний production</h2>
	</div>
	<div class="skill-matrix">
		{
			groups.map((group) => (
				<article class="panel">
					<h3>{group.title}</h3>
					<ul class="chip-list">
						{group.items.map((item) => <li>{item}</li>)}
					</ul>
				</article>
			))
		}
	</div>
</section>
