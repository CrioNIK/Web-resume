---
import { buildPagePath, type PageKey } from '../../i18n/pageCopy';
import type { Lang } from '../../i18n/siteCopy';
import type { NavRouteItem } from '../../lib/routes';

interface Props {
	navItems: NavRouteItem[];
	brandMeta: string;
	homeHref: string;
	currentLang: Lang;
	currentPage: PageKey;
	navigationLabel: string;
	languageLabel: string;
	languageNames: Record<Lang, string>;
	languageLinks?: Partial<Record<Lang, string>>;
}

const { navItems, brandMeta, homeHref, currentLang, currentPage, navigationLabel, languageLabel, languageNames, languageLinks = {} } = Astro.props;

const languageOptions = [
	{ code: 'uk' as const, short: 'UA', href: languageLinks.uk ?? buildPagePath('uk', currentPage) },
	{ code: 'en' as const, short: 'EN', href: languageLinks.en ?? buildPagePath('en', currentPage) }
];
---

<header class="top-nav">
	<a href={homeHref} class="brand-mark" data-route-link="true" data-sound-hover="true">
		<span class="brand-mark__id">MB</span>
		<span class="brand-mark__meta">{brandMeta}</span>
	</a>
	<div class="top-nav__cluster">
		<nav aria-label={navigationLabel}>
			<ul class="top-nav__list">
				{
					navItems.map((item) => (
						<li>
							<a
								href={item.href}
								class:list={['top-nav__link', item.key === currentPage && 'is-active']}
								aria-current={item.key === currentPage ? 'page' : undefined}
								data-route-link="true"
								data-sound-hover="true"
							>
								{item.label}
							</a>
						</li>
					))
				}
			</ul>
		</nav>
		<div class="lang-switch" aria-label={languageLabel}>
			<span class="lang-switch__label">{languageLabel}</span>
			<div class="lang-switch__list">
				{
					languageOptions.map((item) => (
						<a
							href={item.href}
							class:list={['lang-switch__link', item.code === currentLang && 'is-active']}
							aria-label={`${languageLabel}: ${languageNames[item.code]}`}
							aria-current={item.code === currentLang ? 'page' : undefined}
							data-lang-switch={item.code}
							data-route-link="true"
							data-sound-hover="true"
						>
							{item.short}
						</a>
					))
				}
			</div>
		</div>
	</div>
</header>
