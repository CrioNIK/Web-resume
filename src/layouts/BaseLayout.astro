---
import type { Lang } from '../i18n/siteCopy';
import '../styles/global.css';

interface AlternateLink {
	lang: string;
	href: string;
}

interface Props {
	title?: string;
	description?: string;
	canonical?: string;
	lang?: Lang;
	alternates?: AlternateLink[];
}

const {
	title = 'Mykyta Baturin | Middle Frontend Developer (React / Next.js)',
	description = 'Interactive web resume for a Middle Frontend Developer focused on React, Next.js, TypeScript, PWA, SSR, and polished UX motion.',
	canonical,
	lang = 'uk',
	alternates = []
} = Astro.props;

const pageUrl = canonical ?? Astro.url?.href ?? 'http://localhost/';
const locale = lang === 'uk' ? 'uk_UA' : 'en_US';
const personName = lang === 'uk' ? 'Батурін Микита' : 'Mykyta Baturin';
const storageKey = 'resume-lang';

const personSchema = {
	'@context': 'https://schema.org',
	'@type': 'Person',
	name: personName,
	jobTitle: 'Middle Frontend Developer (React / Next.js)',
	email: 'mailto:coldboycrio314@gmail.com',
	telephone: '+380953147381',
	url: pageUrl,
	inLanguage: lang,
	address: {
		'@type': 'PostalAddress',
		addressLocality: 'Kyiv',
		addressCountry: 'UA'
	},
	sameAs: ['https://www.dnd-codex.guide/'],
	knowsAbout: [
		'React',
		'Next.js',
		'TypeScript',
		'TanStack Query',
		'Tailwind CSS',
		'Framer Motion',
		'PWA',
		'SSR'
	]
};
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#15070c" />
		<link rel="canonical" href={pageUrl} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		{
			alternates.map((alternate) => <link rel="alternate" hrefLang={alternate.lang} href={alternate.href} />)
		}
		{
			alternates.length > 0 && (
				<link rel="alternate" hrefLang="x-default" href={alternates.find((item) => item.lang === 'en')?.href ?? alternates[0].href} />
			)
		}

		<meta property="og:type" content="website" />
		<meta property="og:locale" content={locale} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={pageUrl} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Exo+2:wght@400;500;600;700;800&family=Russo+One&display=swap"
			rel="stylesheet"
		/>

		<title>{title}</title>
		<script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
		<script is:inline define:vars={{ lang, storageKey }}>
			(() => {
				const persistLanguage = (value) => {
					try {
						window.localStorage.setItem(storageKey, value);
					} catch {
						return;
					}
				};

				persistLanguage(lang);

				const bindSwitches = () => {
					document.querySelectorAll('[data-lang-switch]').forEach((element) => {
						element.addEventListener(
							'click',
							() => {
								const nextLang = element.getAttribute('data-lang-switch');
								if (nextLang === 'uk' || nextLang === 'en') {
									persistLanguage(nextLang);
								}
							},
							{ passive: true }
						);
					});
				};

				if (document.readyState === 'loading') {
					document.addEventListener('DOMContentLoaded', bindSwitches, { once: true });
				} else {
					bindSwitches();
				}
			})();
		</script>
	</head>
	<body>
		<div class="grain-overlay" aria-hidden="true"></div>
		<div class="scanline-overlay" aria-hidden="true"></div>
		<div class="vignette-overlay" aria-hidden="true"></div>
		<slot />
	</body>
</html>
