---
import HeroIntro from '../../components/astro/HeroIntro.astro';
import HomeModules from '../../components/astro/HomeModules.astro';
import PageBanner from '../../components/astro/PageBanner.astro';
import TopNav from '../../components/astro/TopNav.astro';
import { buildPagePath, type NavPageKey } from '../../i18n/pageCopy';
import { pageCopy } from '../../i18n/pageCopy';
import { siteCopy } from '../../i18n/siteCopy';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildNavRoutes, getAlternates, getStaticLangPaths, resolveLang } from '../../lib/routes';

export function getStaticPaths() {
	return getStaticLangPaths();
}

const lang = resolveLang(Astro.params.lang);
const copy = siteCopy[lang];
const page = pageCopy[lang];
const origin = Astro.site ?? Astro.url;
const canonical = new URL(buildPagePath(lang, 'home'), origin).href;
const alternates = getAlternates(origin, 'home');
const navItems = buildNavRoutes(lang, page.nav);
const homeHref = buildPagePath(lang, 'home');
const modules = navItems.map((item) => ({
	key: item.key as NavPageKey,
	href: item.href,
	...page.home.moduleCards[item.key]
}));
---

<BaseLayout
	title={copy.meta.title}
	description={copy.meta.description}
	canonical={canonical}
	lang={lang}
	alternates={alternates}
	pageKey="home"
>
	<main id="top">
		<TopNav
			navItems={navItems}
			brandMeta={copy.brandMeta}
			homeHref={homeHref}
			currentLang={lang}
			currentPage="home"
			navigationLabel={copy.navigationLabel}
			languageLabel={copy.languageLabel}
			languageNames={copy.languageNames}
		/>
		<PageBanner
			eyebrow={page.home.eyebrow}
			title={page.home.title}
			summary={page.home.summary}
			node={page.home.node}
			signalLabel={page.signalLabel}
		/>
		<section class="section-shell home-profile-shell">
			<HeroIntro hero={copy.hero} />
		</section>
		<HomeModules
			eyebrow={page.home.modulesEyebrow}
			title={page.home.modulesTitle}
			summary={page.home.modulesSummary}
			actionLabel={page.home.moduleAction}
			modules={modules}
		/>
	</main>
</BaseLayout>
